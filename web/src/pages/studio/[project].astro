---
import StudioEditor from '../../components/StudioEditor.tsx'

const { project } = Astro.params
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="viewport" content="width=device-width" />
		<title>Arena — {project}</title>
		<style>
			html,
			body {
				margin: 0;
				height: 100%;
				overflow: hidden;
				background: #0b0d10;
			}
		</style>
	</head>
	<body>
		<StudioEditor client:only="react" projectId={project as string} />
	</body>
</html>
